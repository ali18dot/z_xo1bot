# ── Spam detection ─────────────────────────────────────────────────────────────
URL_RE = re.compile(
    r"(https?://|www\.|t\.me/|telegram\.me/|bit\.ly/|tinyurl\.com/)\S+",
    re.IGNORECASE,
)
SPAM_WORDS = [
    "إعلان", "ربح سريع", "دخل يومي", "اشتراك مجاني", "كسب المال",
    "استثمار", "عروض", "خصم", "مجاناً", "وظائف منزلية",
    "crypto", "bitcoin", "investment", "forex", "profit",
    "join now", "click here", "free money",
]

# ── In-memory flood tracker ────────────────────────────────────────────────────
_flood: dict = defaultdict(lambda: defaultdict(deque))

