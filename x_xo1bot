def load_settings(data_file: str) -> dict:
    if os.path.exists(data_file):
        with open(data_file, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}

def save_settings(data_file: str, settings: dict) -> None:
    os.makedirs(os.path.dirname(os.path.abspath(data_file)), exist_ok=True)
    with open(data_file, "w", encoding="utf-8") as f:
        json.dump(settings, f, ensure_ascii=False, indent=2)

def get_factory_config(settings: dict) -> dict:
    return settings.get("_factory_config", {"channels": [], "custom_buttons": []})

def get_bot_config(settings: dict) -> dict:
    if "_bot_config" not in settings:
        settings["_bot_config"] = {
            "mandatory_channels": [],
            "mandatory_enabled":  False,
            "created_at":         datetime.datetime.now().isoformat(),
        }
    return settings["_bot_config"]

def is_chat_allowed(settings: dict, chat_id: str, username: str) -> bool:
    allowed = get_factory_config(settings).get("channels", [])
    if not allowed:
        return True
    return chat_id in allowed or (username and f"@{username}" in allowed)

def get_group(settings: dict, chat_id: str) -> dict:
    if chat_id not in settings:
        settings[chat_id] = {
            "anti_spam": True, "anti_flood": True, "welcome": True,
            "welcome_msg": "👋 مرحباً {name} في {group}! يسعدنا انضمامك.",
            "flood_limit": 5, "flood_seconds": 10, "warn_limit": 3,
            "warnings": {},
            "stats": {"spam": 0, "flood": 0, "bans": 0, "kicks": 0, "mutes": 0},
        }
    g = settings[chat_id]
    for k, v in [("stats", {}), ("warnings", {}), ("anti_spam", True),
                 ("anti_flood", True), ("welcome", True), ("warn_limit", 3),
                 ("flood_limit", 5), ("flood_seconds", 10)]:
        if k not in g:
            g[k] = v
    return g

def track_group(settings: dict, chat) -> bool:
    """Add group to _groups registry. Returns True if newly added."""
    groups = settings.setdefault("_groups", {})
    chat_id = str(chat.id)
    if chat_id not in groups:
        groups[chat_id] = {
            "title":    chat.title or "",
            "username": getattr(chat, "username", "") or "",
            "joined":   datetime.datetime.now().isoformat(),
        }
        return True
    return False

def total_stats(settings: dict) -> dict:
    """Aggregate stats across all groups."""
    totals = {"spam": 0, "flood": 0, "bans": 0, "kicks": 0, "mutes": 0, "groups": 0}
    for k, v in settings.items():
        if k.startswith("_") or not isinstance(v, dict):
            continue
        totals["groups"] += 1
        for stat in ("spam", "flood", "bans", "kicks", "mutes"):
            totals[stat] += v.get("stats", {}).get(stat, 0)
    return totals

def is_spam(text: str) -> bool:
    if URL_RE.search(text):
        return True
    low = text.lower()
    return any(w.lower() in low for w in SPAM_WORDS)

def parse_duration(s: str) -> int | None:
    m = re.fullmatch(r"(\d+)([smhd])", s.strip().lower())
    if not m:
        return None
    n, unit = int(m.group(1)), m.group(2)
    return n * {"s": 1, "m": 60, "h": 3600, "d": 86400}[unit]

async def resolve_target(update: Update, context: ContextTypes.DEFAULT_TYPE):
    msg = update.message
    if msg.reply_to_message:
        u = msg.reply_to_message.from_user
        return u.id, u.first_name
    if context.args:
        arg = context.args[0].lstrip("@")
        try:
            member = await context.bot.get_chat_member(msg.chat_id, arg)
            return member.user.id, member.user.first_name
        except Exception:
            pass
    return None, None

async def is_admin(bot, chat_id: int, user_id: int) -> bool:
    try:
        m = await bot.get_chat_member(chat_id, user_id)
        return m.status in (ChatMemberStatus.ADMINISTRATOR, ChatMemberStatus.OWNER)
    except Exception:
        return False

async def require_admin(update: Update, context: ContextTypes.DEFAULT_TYPE) -> bool:
    if not await is_admin(context.bot, update.effective_chat.id, update.effective_user.id):
        await update.message.reply_text("⛔ هذا الأمر للمشرفين فقط.")
        return False
    return True

async def check_mandatory(bot, user_id: int, settings: dict) -> list:
    """Return list of channel IDs the user is NOT subscribed to."""
    bc = get_bot_config(settings)
    if not bc.get("mandatory_enabled", False):
        return []
    unsubscribed = []
    for ch in bc.get("mandatory_channels", []):
        try:
            member = await bot.get_chat_member(chat_id=ch, user_id=user_id)
            if member.status in ("left", "kicked", "banned"):
                unsubscribed.append(ch)
        except TelegramError:
            pass
    return unsubscribed

