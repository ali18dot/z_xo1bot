def make_handlers(data_file: str, bot_name: str, owner_id: int):

    def is_owner(user_id: int) -> bool:
        return owner_id != 0 and user_id == owner_id

    # ════════════════════════════════════
    # /start — owner gets admin panel, others get info card
    # ════════════════════════════════════
    async def cmd_start(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
        settings       = load_settings(data_file)
        factory_config = get_factory_config(settings)
        custom_buttons = factory_config.get("custom_buttons", [])
        user_id        = update.effective_user.id

        if update.effective_chat.type == "private":
            if is_owner(user_id):
                # Show full admin panel
                _state.pop(user_id, None)
                st = total_stats(settings)
                groups_count = len(settings.get("_groups", {}))
                await update.message.reply_text(
                    f"🛡 *لوحة تحكم البوت*\n\n"
                    f"الاسم: «{bot_name}»\n"
                    f"الإصدار: {BOT_VERSION}\n\n"
                    f"📊 إجمالي:\n"
                    f"  👥 مجموعات: {groups_count}\n"
                    f"  🚫 سبام: {st['spam']} | 🌊 فيضان: {st['flood']}\n"
                    f"  🔨 حظر: {st['bans']} | 👢 طرد: {st['kicks']} | 🔇 كتم: {st['mutes']}",
                    parse_mode="Markdown",
                    reply_markup=admin_panel_kb(),
                )
            else:
                # Regular users: info card + custom buttons
                kb = None
                if custom_buttons:
                    rows = [[InlineKeyboardButton(b["text"], url=b["url"])]
                            for b in custom_buttons if b.get("url")]
                    if rows:
                        kb = InlineKeyboardMarkup(rows)
                await update.message.reply_text(
                    f"👋 أنا «{bot_name}» — بوت حماية المجموعات.\n\n"
                    "أضفني لمجموعتك كمشرف:\n"
                    "🚫 حذف السبام والإعلانات\n"
                    "🌊 إيقاف الفيضان\n"
                    "👋 ترحيب بالأعضاء الجدد\n\n"
                    "أوامر المشرفين:\n"
                    "/ban /kick /mute /unmute /warn /unwarn /settings",
                    reply_markup=kb,
                )
        else:
            # In groups: show status
            chat_id = str(update.effective_chat.id)
            g       = get_group(settings, chat_id)
            def icon(v): return "✅" if v else "❌"
            kb = None
            if custom_buttons:
                rows = [[InlineKeyboardButton(b["text"], url=b["url"])]
                        for b in custom_buttons if b.get("url")]
                if rows:
                    kb = InlineKeyboardMarkup(rows)
            await update.message.reply_text(
                f"🛡 *{bot_name}* — بوت الحماية\n\n"
                f"{icon(g['anti_spam'])} مكافحة السبام\n"
                f"{icon(g['anti_flood'])} مكافحة الفيضان\n"
                f"{icon(g['welcome'])} رسالة الترحيب\n\n"
                f"أوامر المشرفين: /ban /kick /mute /warn /settings",
                parse_mode="Markdown",
                reply_markup=kb,
            )

# ════════════════════════════════════
    # Private text messages (state machine for owner)
    # ════════════════════════════════════
    async def on_private_text(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
        user_id = update.effective_user.id
        if not is_owner(user_id):
            return
        state_info = _state.get(user_id, {})
        state      = state_info.get("state")
        text       = update.message.text.strip()

        if state == "broadcast_msg":
            settings = load_settings(data_file)
            groups   = settings.get("_groups", {})
            sent = failed = 0
            for gid in groups:
                try:
                    await ctx.bot.send_message(int(gid), text)
                    sent += 1
                except Exception:
                    failed += 1
            _state.pop(user_id, None)
            await update.message.reply_text(
                f"📢 *اكتملت الإذاعة*\n\n✅ أُرسلت إلى: {sent} مجموعة\n❌ فشل: {failed}",
                parse_mode="Markdown",
                reply_markup=admin_panel_kb(),
            )

        elif state == "add_mandatory_ch":
            ch = text.strip()
            if not (ch.startswith("@") or ch.startswith("-")):
                await update.message.reply_text(
                    "❌ يجب أن يبدأ المعرف بـ @ أو رقم سالب (ID)\nأرسله مرة أخرى:"
                )
                return
            settings = load_settings(data_file)
            bc = get_bot_config(settings)
            if ch not in bc.get("mandatory_channels", []):
                bc.setdefault("mandatory_channels", []).append(ch)
                save_settings(data_file, settings)
            _state.pop(user_id, None)
            await update.message.reply_text(
                f"✅ تمت إضافة القناة الإجبارية: {ch}",
                parse_mode="Markdown",
                reply_markup=mandatory_kb(settings),
            )

