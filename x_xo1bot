    # ════════════════════════════════════
    # Welcome new members + track group
    # ════════════════════════════════════
    async def on_new_member(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
        chat     = update.effective_chat
        chat_id  = str(chat.id)
        settings = load_settings(data_file)

        if not is_chat_allowed(settings, chat_id, chat.username or ""):
            return

        changed = track_group(settings, chat)
        if changed:
            save_settings(data_file, settings)

        g = get_group(settings, chat_id)
        if not g["welcome"]:
            return
        group_name = chat.title or "المجموعة"
        for member in update.message.new_chat_members:
            if member.is_bot:
                continue
            name    = member.first_name or member.username or "عضو"
            mention = f"[{name}](tg://user?id={member.id})"
            msg     = g["welcome_msg"].replace("{name}", mention).replace("{group}", group_name)
            await update.message.reply_text(msg, parse_mode="Markdown")

    # ════════════════════════════════════
    # Anti-spam / Anti-flood message filter
    # ════════════════════════════════════
    async def on_message(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
        msg = update.message
        if not msg or not msg.from_user:
            return
        chat    = update.effective_chat
        user    = msg.from_user
        chat_id = str(chat.id)
        settings = load_settings(data_file)

        if not is_chat_allowed(settings, chat_id, chat.username or ""):
            return

        # Track group
        if track_group(settings, chat):
            save_settings(data_file, settings)

        g = get_group(settings, chat_id)

        # Skip admins and bot owner
        if await is_admin(ctx.bot, chat.id, user.id) or is_owner(user.id):
            return

        text = msg.text or msg.caption or ""

        # ── Mandatory subscription check ──
        unsubscribed = await check_mandatory(ctx.bot, user.id, settings)
        if unsubscribed:
            ch_list = "\n".join(
                [f"• [اشترك هنا](https://t.me/{c.lstrip('@')})" for c in unsubscribed]
            )
            kb = InlineKeyboardMarkup([
                [InlineKeyboardButton(
                    f"📢 اشترك في {c}",
                    url=f"https://t.me/{c.lstrip('@')}"
                )] for c in unsubscribed
            ])
            await chat.send_message(
                f"⛔ [{user.first_name}](tg://user?id={user.id})، "
                f"يجب الاشتراك في القنوات التالية للمشاركة:\n{ch_list}",
                parse_mode="Markdown",
                reply_markup=kb,
            )
            try:
                await msg.delete()
            except Exception:
                pass
            return

        # ── Anti-spam ──
        if g["anti_spam"] and is_spam(text):
            try:
                await msg.delete()
            except Exception:
                pass
            g["stats"]["spam"] = g["stats"].get("spam", 0) + 1
            uid_str = str(user.id)
            g["warnings"][uid_str] = g["warnings"].get(uid_str, 0) + 1
            warns      = g["warnings"][uid_str]
            warn_limit = g.get("warn_limit", 3)
            if warns >= warn_limit:
                try:
                    await ctx.bot.ban_chat_member(chat.id, user.id)
                    g["stats"]["bans"] = g["stats"].get("bans", 0) + 1

g["warnings"][uid_str] = 0
                    await chat.send_message(
                        f"🚫 تم حظر [{user.first_name}](tg://user?id={user.id}) "
                        f"بسبب تكرار السبام ({warn_limit} تحذيرات).",
                        parse_mode="Markdown",
                    )
                except Exception:
                    pass
            else:
                remaining = warn_limit - warns
                await chat.send_message(
                    f"⚠️ [{user.first_name}](tg://user?id={user.id}) "
                    f"تحذير {warns}/{warn_limit} — رسالة مزعجة. ({remaining} متبقية قبل الحظر)",
                    parse_mode="Markdown",
                )
            save_settings(data_file, settings)
            return

        # ── Anti-flood ──
        if g["anti_flood"]:
            now    = datetime.datetime.now().timestamp()
            limit  = g.get("flood_limit", 5)
            window = g.get("flood_seconds", 10)
            dq     = _flood[chat_id][str(user.id)]
            dq.append(now)
            while dq and dq[0] < now - window:
                dq.popleft()
            if len(dq) >= limit:
                dq.clear()
                try:
                    until = datetime.datetime.now(datetime.timezone.utc) + datetime.timedelta(hours=1)
                    await ctx.bot.restrict_chat_member(
                        chat.id, user.id,
                        permissions=ChatPermissions(can_send_messages=False),
                        until_date=until,
                    )
                    g["stats"]["mutes"]  = g["stats"].get("mutes", 0) + 1
                    g["stats"]["flood"]  = g["stats"].get("flood", 0) + 1
                    save_settings(data_file, settings)
                    await chat.send_message(
                        f"🌊 [{user.first_name}](tg://user?id={user.id}) "
                        f"تم كتمه لمدة ساعة بسبب الفيضان.",
                        parse_mode="Markdown",
                    )
                except Exception:
                    pass

