def run_bot(token: str, data_file: str, bot_name: str, owner_id: int = 0) -> None:
    """Synchronous entry — app.run_polling() manages its own event loop."""
    os.makedirs(os.path.dirname(os.path.abspath(data_file)), exist_ok=True)

# Initialise bot_config on first run
    settings = load_settings(data_file)
    bc = get_bot_config(settings)
    if "created_at" not in bc:
        bc["created_at"] = datetime.datetime.now().isoformat()
        save_settings(data_file, settings)

    app = Application.builder().token(token).build()
    for h in make_handlers(data_file, bot_name, owner_id):
        app.add_handler(h)
    logger.info(f"Protection bot «{bot_name}» started. owner_id={owner_id}")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--token",     required=True)
    parser.add_argument("--data-file", required=True)
    parser.add_argument("--name",      required=True)
    parser.add_argument("--owner-id",  type=int, default=0)
    args = parser.parse_args()
    run_bot(args.token, args.data_file, args.name, args.owner_id)


if name == "main":
    main()
